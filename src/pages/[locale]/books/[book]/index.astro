---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { bookTitleWithCount, chapterCountLabel, chapterHref, copy, localizeBook, routedLocales, type RoutedLocale } from "../../../../lib/i18n";
import { getBooks, groupedChapters, localizeChapters } from "../../../../lib/books";
export function getStaticPaths() { return routedLocales.flatMap((locale) => getBooks().map((book) => ({ params: { locale: locale.toLowerCase(), book: book.slug }, props: { locale, originalBook: book } }))); }
const locale = Astro.props.locale as RoutedLocale; const originalBook = Astro.props.originalBook; const book = localizeBook(originalBook, locale); const ui = copy[locale]; const groups = groupedChapters({ chapters: localizeChapters(originalBook, locale) });
---
<BaseLayout locale={locale} title={`${bookTitleWithCount(book, locale)} · MEJE BOOKS`} description={book.description}>
  <section class="book-hero"><div class="container book-hero-grid"><div><p class="eyebrow">{book.line} · {book.category}</p><h1>{bookTitleWithCount(book, locale)}</h1><p class="subtitle">{book.subtitle}</p><p class="edition-note">{ui.originalAvailable}</p></div><aside class="book-panel">{book.cover && <img class="book-panel-cover" src={book.cover} alt={book.title} />}<dl><dt>{ui.author}</dt><dd>{book.author}</dd><dt>{ui.chapters}</dt><dd>{chapterCountLabel(book, locale)}</dd><dt>{ui.assets}</dt><dd>{book.assetCount ?? 0}</dd><dt>{ui.line}</dt><dd>{book.line}</dd></dl></aside></div></section>
  <section class="section"><div class="container"><div class="section-head"><h2 class="section-title">{ui.contents}</h2><p class="section-meta">{chapterCountLabel(book, locale)}</p></div><div class="chapter-sections">{groups.map(([section, chapters]) => <section class="chapter-section"><div class="chapter-section-head"><h3>{section}</h3><p>{chapters.length} {ui.chapters}</p></div><div class="chapter-list">{chapters.map((chapter) => <a class="chapter-row" href={chapterHref(originalBook, chapter, locale)}><span class="num">{String(chapter.order).padStart(2,"0")}</span><span class="title">{chapter.title}</span></a>)}</div></section>)}</div></div></section>
</BaseLayout>
