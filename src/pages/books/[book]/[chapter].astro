---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getBooks, getChapter } from "../../../lib/books";

export async function getStaticPaths() {
  const paths = [];
  for (const book of getBooks()) {
    for (const chapter of book.chapters) {
      paths.push({
        params: { book: book.slug, chapter: chapter.slug },
        props: { bookSlug: book.slug, chapterSlug: chapter.slug }
      });
    }
  }
  return paths;
}

const data = await getChapter(Astro.props.bookSlug, Astro.props.chapterSlug);
if (!data) {
  throw new Error("Chapter not found");
}
const { book, chapter, html, prev, next } = data;
---
<BaseLayout title={`${chapter.title} · ${book.title}`} description={book.description}>
  <div class="reader-wrap">
    <aside class="reader-aside" aria-label="목차">
      <a href={`/books/${book.slug}/`}>← {book.title}</a>
      {book.chapters.map((item) => (
        <a
          class={item.slug === chapter.slug ? "active" : ""}
          href={`/books/${book.slug}/${item.slug}/`}
        >
          {String(item.order).padStart(2, "0")}. {item.title}
        </a>
      ))}
    </aside>

    <article class="reader">
      <header class="reader-head">
        <p class="crumb">{book.line} · {book.title}</p>
        <h1>{chapter.title}</h1>
        <div class="reader-meta">{book.author} · Chapter {chapter.order}</div>
      </header>
      <div class="prose" set:html={html} />
      <nav class="reader-nav" aria-label="Chapter navigation">
        {prev ? (
          <a href={`/books/${book.slug}/${prev.slug}/`}>
            <span>Previous</span>
            {prev.title}
          </a>
        ) : <span></span>}
        {next ? (
          <a href={`/books/${book.slug}/${next.slug}/`}>
            <span>Next</span>
            {next.title}
          </a>
        ) : <span></span>}
      </nav>
    </article>
  </div>
</BaseLayout>
