---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { bookTitleWithCount, chapterCountLabel, chapterHref, getBooks, groupedChapters } from "../../../lib/books";

export function getStaticPaths() {
  return getBooks().map((book) => ({
    params: { book: book.slug },
    props: { book }
  }));
}

const { book } = Astro.props;
const chapterGroups = groupedChapters(book);
---
<BaseLayout title={`${bookTitleWithCount(book)} · MEJE BOOKS`} description={book.description}>
  <section class="book-hero">
    <div class="container book-hero-grid">
      <div>
        <p class="eyebrow">{book.line} · {book.category}</p>
        <h1>{bookTitleWithCount(book)}</h1>
        <p class="subtitle">{book.subtitle}</p>
      </div>
      <aside class="book-panel">
        {book.cover && (
          <img class="book-panel-cover" src={book.cover} alt={`${book.title} 표지`} />
        )}
        <dl>
          <dt>Author</dt>
          <dd>{book.author}</dd>
          <dt>Pieces</dt>
          <dd>{chapterCountLabel(book)}</dd>
          <dt>Assets</dt>
          <dd>{book.assetCount ?? 0}</dd>
          <dt>Line</dt>
          <dd>{book.line}</dd>
        </dl>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">목차</h2>
        <p class="section-meta">{chapterCountLabel(book)}</p>
      </div>
      {book.chapters.length === 0 ? (
        <p class="empty">아직 공개된 챕터가 없습니다.</p>
      ) : (
        <div class="chapter-sections">
          {chapterGroups.map(([section, chapters]) => (
            <section class="chapter-section" id={section.replace(/\s+/g, "-").toLowerCase()}>
              <div class="chapter-section-head">
                <h3>{section}</h3>
                <p>{chapters.length}편</p>
              </div>
              <div class="chapter-list">
                {chapters.map((chapter) => (
                  <a class={`chapter-row${chapter.externalUrl ? " external" : ""}`} href={chapterHref(book, chapter)}>
                    <span class="num">{String(chapter.order).padStart(2, "0")}</span>
                    <span class="title">{chapter.title}</span>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
