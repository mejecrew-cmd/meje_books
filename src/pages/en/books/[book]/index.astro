---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { bookTitleWithCount, chapterCountLabel, chapterHref, localizeBook } from "../../../../lib/i18n";
import { getBooks, groupedChapters } from "../../../../lib/books";

export function getStaticPaths() {
  return getBooks().map((book) => ({ params: { book: book.slug }, props: { book } }));
}

const originalBook = Astro.props.book;
const book = localizeBook(originalBook, "en");
const chapterGroups = groupedChapters(originalBook);
---
<BaseLayout locale="en" title={`${bookTitleWithCount(book, "en")} · MEJE BOOKS`} description={book.description}>
  <section class="book-hero">
    <div class="container book-hero-grid">
      <div>
        <p class="eyebrow">{book.line} · {book.category}</p>
        <h1>{bookTitleWithCount(book, "en")}</h1>
        <p class="subtitle">{book.subtitle}</p>
        <p class="edition-note">
          This English entry presents the book's scope and structure. The Korean manuscript remains the published source text.
        </p>
      </div>
      <aside class="book-panel">
        {book.cover && <img class="book-panel-cover" src={book.cover} alt={`${book.title} cover`} />}
        <dl>
          <dt>Author</dt><dd>{book.author}</dd>
          <dt>Chapters</dt><dd>{chapterCountLabel(book, "en")}</dd>
          <dt>Assets</dt><dd>{book.assetCount ?? 0}</dd>
          <dt>Line</dt><dd>{book.line}</dd>
        </dl>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">Contents</h2>
        <p class="section-meta">{chapterCountLabel(book, "en")}</p>
      </div>
      <div class="chapter-sections">
        {chapterGroups.map(([section, chapters]) => (
          <section class="chapter-section" id={section.replace(/\s+/g, "-").toLowerCase()}>
            <div class="chapter-section-head">
              <h3>{section}</h3>
              <p>{chapters.length} chapters</p>
            </div>
            <div class="chapter-list">
              {chapters.map((chapter) => (
                <a class={`chapter-row${chapter.externalUrl ? " external" : ""}`} href={chapterHref(originalBook, chapter, "en")}>
                  <span class="num">{String(chapter.order).padStart(2, "0")}</span>
                  <span class="title"><span class="original-title">{chapter.title}</span><small>Korean original</small></span>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
