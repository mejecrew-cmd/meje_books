---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { bookHref, bookTitleWithCount, chapterHref, copy, localizeBook } from "../../../../lib/i18n";
import { getBooks, getChapter, groupedChapters, localizeChapters } from "../../../../lib/books";

export async function getStaticPaths() {
  const paths = [];
  for (const book of getBooks()) {
    for (const chapter of book.chapters) {
      if (chapter.externalUrl) continue;
      paths.push({ params: { book: book.slug, chapter: chapter.slug }, props: { bookSlug: book.slug, chapterSlug: chapter.slug } });
    }
  }
  return paths;
}

const data = await getChapter(Astro.props.bookSlug, Astro.props.chapterSlug, "en");
if (!data) throw new Error("Chapter not found");
const { book: originalBook, chapter, html, isTranslation, translationTitle, prev, next } = data;
const book = localizeBook(originalBook, "en");
const ui = copy.en;
const localizedChapters = localizeChapters(originalBook, "en");
const chapterGroups = groupedChapters({ chapters: localizedChapters });
const localizedTitle = (item: typeof chapter | undefined) => item
  ? (localizedChapters.find((candidate) => candidate.slug === item.slug)?.title ?? item.title)
  : "";
const chapterTitle = translationTitle ?? localizedTitle(chapter);
---
<BaseLayout locale="en" title={`${chapterTitle} · ${bookTitleWithCount(book, "en")}`} description={book.description}>
  <div class="reader-wrap">
    <aside class="reader-aside" aria-label="Contents">
      <a href={bookHref(originalBook, "en")}>← {bookTitleWithCount(book, "en")}</a>
      {chapterGroups.map(([section, chapters]) => (
        <div class="reader-section">
          <p>{section}</p>
          {chapters.map((item) => (
            <a class={item.slug === chapter.slug ? "active" : ""} href={chapterHref(originalBook, item, "en")}>
              {String(item.order).padStart(2, "0")}. {item.title}
            </a>
          ))}
        </div>
      ))}
    </aside>

    <article class="reader">
      <header class="reader-head">
        <p class="crumb">{book.line} · {bookTitleWithCount(book, "en")}</p>
        <h1>{chapterTitle}</h1>
        <div class="reader-meta">{book.author} · Chapter {chapter.order}</div>
      </header>
      {isTranslation ? (
        <div class="prose" set:html={html} />
      ) : (
        <section class="translation-notice">
          <p class="eyebrow">KOREAN ORIGINAL</p>
          <h2>This chapter is currently published in Korean.</h2>
          <p>Open the Korean source manuscript to read the complete chapter.</p>
          <a class="original-link" href={`/books/${originalBook.slug}/${chapter.slug}/`}>{ui.readOriginal}</a>
        </section>
      )}
      <nav class="reader-nav" aria-label={ui.chapterNavigation}>
        {prev ? <a href={chapterHref(originalBook, prev, "en")}><span>{ui.previous}</span>{localizedTitle(prev)}</a> : <span></span>}
        {next ? <a href={chapterHref(originalBook, next, "en")}><span>{ui.next}</span>{localizedTitle(next)}</a> : <span></span>}
      </nav>
    </article>
  </div>
</BaseLayout>
