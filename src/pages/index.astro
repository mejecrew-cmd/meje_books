---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBooks, getLineGroups } from "../lib/books";

const books = getBooks();
const groups = getLineGroups();
---
<BaseLayout title="MEJE BOOKS" description="MEJE Works 공개 원고와 강연고를 책 단위로 읽는 공간">
  <section class="hero">
    <div class="container">
      <p class="eyebrow">MEJE PUBLIC MANUSCRIPTS</p>
      <h1>브런치 밖에서도 원고를 책처럼 읽는 자리</h1>
      <p>
        MEJE의 제작 절차, 김동은WhtDrgon.의 강연고, 세계관과 비즈니스 모델 원고를 책 단위로 묶었습니다.
        각 책은 목차와 챕터 읽기 화면을 갖춘 정적 아카이브로 관리됩니다.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">전체 책</h2>
        <p class="section-meta">{books.length} books</p>
      </div>
      <div class="book-grid">
        {books.map((book) => (
          <a class="book-card" href={`/books/${book.slug}/`}>
            {book.cover && (
              <img class="book-thumb" src={book.cover} alt={`${book.title} 표지`} loading="lazy" />
            )}
            <span class="line">{book.line} · {book.category}</span>
            <h2>{book.title}</h2>
            <p>{book.description}</p>
            <span class="card-foot">
              <span>{book.author}</span>
              <span>{book.chapterCount} chapters</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {groups.map(([line, lineBooks]) => (
    <section class="section">
      <div class="container">
        <div class="section-head">
          <h2 class="section-title">{line}</h2>
          <p class="section-meta">{lineBooks.length} books</p>
        </div>
        <div class="book-grid">
          {lineBooks.map((book) => (
            <a class="book-card" href={`/books/${book.slug}/`}>
              {book.cover && (
                <img class="book-thumb" src={book.cover} alt={`${book.title} 표지`} loading="lazy" />
              )}
              <span class="line">{book.category}</span>
              <h3>{book.title}</h3>
              <p>{book.subtitle}</p>
              <span class="card-foot">
                <span>목차 보기</span>
                <span>{book.chapterCount}</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}
</BaseLayout>
