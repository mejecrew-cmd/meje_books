---
import BaseLayout from "../layouts/BaseLayout.astro";
import { bookTitleWithCount, chapterCountLabel, getBooks, getLineGroups } from "../lib/books";

const books = getBooks();
const groups = getLineGroups();
---
<BaseLayout title="Books of MEJE Knowledge" description="MEJE의 제작 절차, 강연고, 세계관과 비즈니스 모델 원고를 책 단위로 정리한 공개 라이브러리">
  <section class="hero">
    <div class="container">
      <p class="eyebrow">MEJE BOOKS</p>
      <h1>Books of MEJE Knowledge</h1>
      <p>
        MEJE의 제작 절차, 김동은WhtDrgon.의 강연고, 세계관과 비즈니스 모델 원고를 책 단위로 정리했습니다.
        목차, 챕터, 이전/다음 이동을 갖춘 공개 라이브러리입니다.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">전체 책</h2>
        <p class="section-meta">{books.length}권</p>
      </div>
      <div class="book-grid">
        {books.map((book) => (
          <a class="book-card" href={`/books/${book.slug}/`}>
            {book.cover && (
              <img class="book-thumb" src={book.cover} alt={`${book.title} 표지`} loading="lazy" />
            )}
            <span class="line">{book.line} · {book.category}</span>
            <h2>{bookTitleWithCount(book)}</h2>
            <p>{book.description}</p>
            <span class="card-foot">
              <span>{book.author}</span>
              <span>{chapterCountLabel(book)}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {groups.map(([line, lineBooks]) => (
    <section class="section">
      <div class="container">
        <div class="section-head">
          <h2 class="section-title">{line}</h2>
          <p class="section-meta">{lineBooks.length}권</p>
        </div>
        <div class="book-grid">
          {lineBooks.map((book) => (
            <a class="book-card" href={`/books/${book.slug}/`}>
              {book.cover && (
                <img class="book-thumb" src={book.cover} alt={`${book.title} 표지`} loading="lazy" />
              )}
              <span class="line">{book.category}</span>
              <h3>{bookTitleWithCount(book)}</h3>
              <p>{book.subtitle}</p>
              <span class="card-foot">
                <span>목차 보기</span>
                <span>{chapterCountLabel(book)}</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}
</BaseLayout>
