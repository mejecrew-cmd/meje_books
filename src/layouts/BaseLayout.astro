---
import "../styles/global.css";
import { copy, localeLabels, locales, localeSegments, localizePath, type Locale } from "../lib/i18n";

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
}

const {
  title = "Books of MEJE Knowledge",
  description = "Books of MEJE Knowledge는 MEJE의 제작 절차, 강연고, 세계관 원고를 책 단위로 정리한 공개 라이브러리입니다.",
  locale = "ko"
} = Astro.props;
const siteUrl = "https://books.meje.kr";
const ui = copy[locale];
const alternatePaths = locales.map((item) => ({ locale: item, path: localizePath(Astro.url.pathname, item) }));
const homeHref = localeSegments[locale] ? `/${localeSegments[locale]}/` : "/";
const booksHref = localeSegments[locale] ? `/${localeSegments[locale]}/books/` : "/books/";
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary" />
    <link rel="canonical" href={Astro.url.href} />
    {alternatePaths.map((item) => <link rel="alternate" hreflang={item.locale} href={`${siteUrl}${item.path}`} />)}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${localizePath(Astro.url.pathname, "ko")}`} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Noto+Serif+KR:wght@500;700;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href={homeHref}>MEJE BOOKS <span>Knowledge Library</span></a>
        <nav class="nav" aria-label={ui.primaryNav}>
          <a href={homeHref}>{ui.home}</a>
          <a href={booksHref}>{ui.books}</a>
          <a href="https://meje.kr">MEJE.kr</a>
          <span class="language-switch" aria-label={ui.languageLabel}>
            {locales.map((item) => (
              <a class={locale === item ? "active" : ""} href={localizePath(Astro.url.pathname, item)}>{localeLabels[item]}</a>
            ))}
          </span>
        </nav>
      </header>
      <main class="main">
        <slot />
      </main>
      <footer class="footer">
        MEJE Works Corp. · Books of MEJE Knowledge.
      </footer>
    </div>
  </body>
</html>
